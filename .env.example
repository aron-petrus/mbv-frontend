# Backend usado pelo proxy local do Vite.
VITE_API_PROXY_TARGET=http://localhost:3001

# Backend usado pela Function /api/* no deploy da Vercel.
# Configure esta variável nas configurações do projeto na Vercel.
API_PROXY_TARGET=https://api.example.com

# Opcional: faz o navegador chamar a API diretamente, sem o proxy /api.
# O backend precisa permitir CORS para o domínio do frontend.
# VITE_API_BASE_URL=https://api.example.com
